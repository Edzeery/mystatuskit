{
    "name": "edzeery/mystatuskit",
    "version": "1.2.0",
    "description": "مكتبة موحّدة لإدارة ألوان وأيقونات الحالات (Status Colors & Icons) في مشاريع Laravel، بدون اعتماد على Filament أو أي حزمة UI خارجية.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "status",
        "badge",
        "icons",
        "colors",
        "fontawesome",
        "bootstrap-icons",
        "ionicons",
        "heroicons"
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "Edzeery\\MyStatusKit\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Edzeery\\MyStatusKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Edzeery\\MyStatusKit\\StatusKitServiceProvider"
            ],
            "aliases": {
                "Status": "Edzeery\\MyStatusKit\\Facades\\Status",
                "Icon": "Edzeery\\MyStatusKit\\Facades\\Icon"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "audit": {
            "block-insecure": false
        },
        "sort-packages": true
    }
}
